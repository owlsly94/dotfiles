{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "´Æë ",
      "2": "´ë¿ ",
      "3": "´äĞ ",
      "4": "´ü╗ ",
      "5": "¾░┐Ä ",
      "6": "´à¬ ",
      "7": "´åÂ ",
      "8": "´ç┐ ",
      "9": "¾░ıç ",
      "10": "´ââ "
    },
    "sort-by-number": true
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close"
  },

  "hyprland/window": {
    "format": "{}",
    "icon": true,
    "separate-outputs": true,
    "max-length": 50
  },

  "cpu": {
    "format": "´ïø  {usage}%",
    "tooltip": false,
    "on-click": "kitty -e btop"
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["´ïê", "´ïè", "´ïë"]
  },

  "memory": {
    "format": "¯┐à  {used} GB",
    "on-click": "kitty -e htop",
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)\nSwap: {swapUsed:0.1f}GB / {swapTotal:0.1f}GB"
  },

  "custom/updates": {
    "format": "´åç  {}",
    "interval": 7200,
    "exec": "sh ~/.config/hypr/scripts/updates.sh",
    "on-click": "exec kitty --app-id topgrade -e topgrade"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¯¼ñ ",
    "format-icons": {
      "default": ["´ÇĞ ", "´Çğ ", "´Ç¿ "]
    },
    "on-click": "pavucontrol"
  },

  "clock": {
    "format": "¾░â░  {:%H:%M %a %e.%b}",
    "rotate": 0,
    "format-alt": "{  %d┬À%m┬À%y}",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
        "mode": "month",
        "format": {
            "months": "<span color='#c792ea'><b>{}</b></span>",
            "days": "<span color='#a6accd'><b>{}</b></span>",
            "weekdays": "<span color='#89ddff'><b>{}</b></span>",
            "today": "<span color='#ffcb6b'><b>{}</b></span>"
        }
    }
  },
  
  "tray": {
    "icon-size": 16,
    "spacing": 10
  }
}
